{
  "name": ".",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "set NODE_OPTIONS=--max-old-space-size=2048 && tinacms dev -c \"next dev --turbo\"",
    "dev:fast": "set NODE_OPTIONS=--max-old-space-size=2048 && next dev --turbo",
    "build": "node --max-old-space-size=4096 ./node_modules/@tinacms/cli/dist/index.js build && next build",
    "build-local": "node --max-old-space-size=4096 ./node_modules/@tinacms/cli/dist/index.js build --local --skip-indexing --skip-cloud-checks && next build",
    "start": "tinacms build && next start",
    "export": "npm run build && next export",
    "lint": "biome lint",
    "dev:build": "next build",
    "tina:pull": "npx tinacms schema:pull",
    "tina:regen": "node --max-old-space-size=4096 ./node_modules/@tinacms/cli/dist/index.js build --local --skip-indexing --skip-cloud-checks"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@svgr/webpack": "^8.1.0",
    "@tinacms/cli": "^2.1.5",
    "@types/js-cookie": "^3.0.6",
    "@types/node": "^22.18.12",
    "@types/react": "^18.3.26",
    "@types/styled-components": "^5.1.34",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "postcss-import": "^16.1.1",
    "postcss-nesting": "^13.0.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.9",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-slot": "^1.2.3",
    "@react-leaflet/core": "^2.1.0",
    "@tailwindcss/postcss": "^4.1.15",
    "@tailwindcss/typography": "^0.5.19",
    "@types/leaflet": "^1.9.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.484.0",
    "mermaid": "^11.12.0",
    "motion": "^12.23.24",
    "next": "15.3.8",
    "next-themes": "^0.4.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.5.0",
    "react-leaflet": "^4.2.1",
    "react-player": "^2.16.1",
    "react-use-measure": "^2.1.7",
    "shiki": "^3.13.0",
    "styled-jsx": "^5.1.7",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^4.1.15",
    "tinacms": "^2.9.0",
    "tw-animate-css": "^1.4.0",
    "usehooks-ts": "^3.1.1"
  }
}
